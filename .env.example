# .env.example

# App
APP_ENV=development
LOG_LEVEL=INFO
TIMEZONE=America/New_York
WATCHLIST_FILE=config/watchlist.yml
STRICT_WATCHLIST_ONLY=true

# Market data provider — ordered real-data fallback chain (NO synthetic prices).
# Valid names: yfinance, finnhub, tiingo, alpha_vantage, stooq, local_cache
MARKET_DATA_PROVIDER=yfinance_dev
MARKET_DATA_PROVIDER_CHAIN=yfinance,finnhub,tiingo,alpha_vantage,stooq,local_cache
MARKET_DATA_API_KEY=
# Extra market-data providers (all key-gated, all real data; leave blank to skip)
FINNHUB_API_KEY=
TIINGO_API_KEY=
ALPHAVANTAGE_API_KEY=
POLYGON_API_KEY=
NASDAQ_DATA_LINK_API_KEY=

# Feature toggles
ENABLE_FORECAST=true          # Monte-Carlo + trend-agent ensemble (real history)
ENABLE_GPU_MONTE_CARLO=false # Optional CuPy/NVIDIA acceleration; CPU fallback remains automatic
MONTE_CARLO_PATHS=4000        # Increase after GPU validation for faster/larger simulations
MIN_OPTION_DAYS_TO_EXPIRY=5   # Options Edge will not consider expiries under this DTE
MIN_INDEX_OPTION_MOVE_POINTS=50 # Index option trades require at least this many expected underlying index points
MIN_OPTION_PROFIT_PCT=5       # Promote option ideas only when est. premium gain (exit-entry) is at least this percentage; below this is "low potential"
ENABLE_GOVERNMENT_FEEDS=true  # Treasury FiscalData / Federal Register / GDELT (keyless)
ENABLE_SOCIAL_SENTIMENT=true  # StockTwits + Reddit (keyless; may need token on cloud IPs)
ENABLE_GLOBAL_MARKETS=true    # US/Europe/Asia index levels + per-ticker correlation (keyless)
ENABLE_HISTORICAL_SNAPSHOTS=true  # Persist each scan for IV Rank, scorecards, ML, and no-lookahead tuning
HISTORICAL_SNAPSHOTS_DIR=data/historical_snapshots
ENABLE_EARNINGS_CALENDAR=true     # Keyless next-earnings lookup (yfinance) for options IV-crush gating
EARNINGS_FETCH_TIMEOUT=6          # Hard per-ticker seconds budget for the earnings lookup (prevents scan stalls)
ENABLE_LLM_SENTIMENT=false        # Use local Ollama (GPU) to classify headline sentiment; lexicon fallback when off/unreachable

# Global markets — leave blank for the built-in set (S&P500, Nasdaq, Dow, DAX,
# CAC40, FTSE100, Euro Stoxx 50, Nikkei 225, Hang Seng, Shanghai, NSE, KOSPI, VIX).
# Override format: "Name=SYMBOL:Region, Name2=SYMBOL2:Region2"
GLOBAL_INDEXES=

# AI advisor (research only). provider: auto | openai | anthropic | ollama | rules
# 'auto' uses an LLM when a cloud key is set; set OLLAMA_BASE_URL or provider=ollama
# to use a local Ollama model. Otherwise it falls back to deterministic rules.
#
# Local GPU (Ollama) setup that is KNOWN-GOOD on this laptop:
#   ADVISOR_PROVIDER=ollama
#   ADVISOR_MODEL=llama3.2:3b      # ~2GB, fits 8GB VRAM; `ollama pull llama3.2:3b`
#   ENABLE_LLM_SENTIMENT=true
# Leave OLLAMA_BASE_URL blank for host-run scans (defaults to http://localhost:11434).
# The Docker container reaches the host's Ollama via host.docker.internal — that
# override is set in docker-compose.yml, so do NOT hard-code localhost here.
ADVISOR_PROVIDER=auto
ADVISOR_MODEL=
OLLAMA_BASE_URL=

# Extra news providers (optional, key-gated; keyless Google News + Yahoo RSS always on)
MARKETAUX_API_KEY=
FMP_API_KEY=

# SEC
SEC_USER_AGENT="your-name your-email@example.com"
SEC_BASE_URL=https://data.sec.gov

# Macro data
# FRED_API_KEY is OPTIONAL. Without it, macro still pulls a real LIVE regime from
# keyless sources (yfinance ^TNX/^FVX/^TYX yields, ^VIX, WTI, dollar index +
# U.S. Treasury FiscalData). Set a free FRED key for the full official series
# (10y/2y curve, fed funds, unemployment, CPI).
FRED_API_KEY=
BLS_API_KEY=
BEA_API_KEY=
EIA_API_KEY=
CONGRESS_API_KEY=

# News/search providers
SERPAPI_API_KEY=
BRAVE_API_KEY=
TAVILY_API_KEY=
NEWS_API_KEY=

# Social providers, optional and only if legally/API enabled.
# X_BEARER_TOKEN enables the official X (Twitter) API v2 connector for company
# news, bull/bear sentiment, and government-handle policy tweets. Requires a PAID
# X API plan (recent-search). Without it, X is cleanly skipped — we never scrape.
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
# Cost guard: max paid X API reads per UTC day (0 = no cap). Reads are counted in
# data/x_api_usage.json; once the budget is hit, X is skipped until the next day.
X_DAILY_READ_BUDGET=50
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
STOCKTWITS_TOKEN=

# Remote access / dashboard auth (research dashboard exposure via Cloudflare Tunnel).
# When DASHBOARD_PASSWORD is set, HTTP Basic login is enforced for tunnel traffic.
# localhost/loopback is always exempt (no prompt on the laptop itself).
DASHBOARD_USER=
DASHBOARD_PASSWORD=
# Set true to ALSO require login for LAN devices (not just the public tunnel).
# Loopback stays exempt either way.
DASHBOARD_REQUIRE_LOGIN_ON_LAN=false

# Alerts
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_TO=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LLM provider, optional
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LLM_MODEL=

# Risk settings
MIN_EQUITY_DAILY_VOLUME=1000000
MIN_OPTION_OPEN_INTEREST=100
MAX_OPTION_BID_ASK_SPREAD_PCT=12
DEFAULT_CONFIDENCE_THRESHOLD=65
PIPELINE_MAX_WORKERS=16
PER_TICKER_RETRIES=1
PER_TICKER_RETRY_DELAY_SECONDS=2
